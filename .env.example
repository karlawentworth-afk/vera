VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Demo switcher — set to 'true' for staging/demo, remove for production
VITE_ENABLE_DEMO_SWITCHER=true

# Service role key — only used by seed script, never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
